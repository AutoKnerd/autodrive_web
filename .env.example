# Stripe server-side keys
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe recurring trial price (AutoDriveCX Individual)
STRIPE_PRICE_ID=price_1SsMKIIqxH0CMe02hpGHxYq0

# Optional fallback base URL for server-side redirects
PUBLIC_SITE_URL=https://your-domain.com

# Optional app login URL used on /trial-success button
VITE_AUTODRIVE_APP_URL=https://app.autodrivecx.com/login

# Gemini API key used by /server/server.js
GEMINI_API_KEY=YOUR_KEY

# Firebase Admin credentials for server-side Firestore writes (preferred)
# Option A: provide individual fields
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# Option B: provide the full JSON service account object as one env var
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"..."}
